{
  "name": "qatar-tenders-history",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run api\" \"npm run web\"",
    "web": "vite --host 0.0.0.0",
    "api": "nodemon --watch server --ext js server/index.js",
    "db:migrate": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "db:seed": "node server/seed.js",
    "db:import": "node server/ingest.js",
    "pull:latest": "node server/pull-and-ingest.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "pg": "^8.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
